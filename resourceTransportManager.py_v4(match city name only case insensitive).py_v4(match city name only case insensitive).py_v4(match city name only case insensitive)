    print(f"  {'':4} {'TOTAL':<18}", end="")
    for i in range(len(materials_names)):
        print(f" {addThousandSeparator(grand_totals[i]):>9}", end="")
    print(f" {total_ships:>7}")
    print("")

    print("  (Y) Proceed with shipments")
    print("  (E) Edit - re-select destination and amounts")
    print("  (C) Cancel - return to main menu")
    choice = read(values=["y", "Y", "e", "E", "c", "C", ""])
    if choice == "" or choice.upper() == "Y":
        return "Y"
    elif choice.upper() == "E":
        return "E"
    else:
        return "C"


def do_it_auto_send(session, routes, useFreighters, telegram_enabled):
    ship_type_name = "freighters" if useFreighters else "merchant ships"
    total_routes = len(routes)
    completed = 0

    print(f"\n--- Auto Send: executing {total_routes} shipments ---\n")

    for route_index, route in enumerate(routes):
        origin_city = route[0]
        destination_city = route[1]
        amounts = route[3:]
        total_cargo = sum(amounts)

        resources_desc = ", ".join(
            f"{addThousandSeparator(amounts[i])} {materials_names[i]}"
            for i in range(len(materials_names)) if i < len(amounts) and amounts[i] > 0
        )

        print(f"  [{route_index + 1}/{total_routes}] {origin_city['name']} -> {destination_city['name']}")
        print(f"    Resources: {resources_desc}")

        ship_check_start = time.time()
        max_ship_wait = 3600
        available_ships = 0

        while True:
            if useFreighters:
                available_ships = getAvailableFreighters(session)
            else:
                available_ships = getAvailableShips(session)

            if available_ships > 0:
                print(f"    Found {available_ships} {ship_type_name}")
                break

            elapsed = int(time.time() - ship_check_start)
            if elapsed > max_ship_wait:
                print(f"    Timed out waiting for {ship_type_name} after {elapsed}s")
                break
            print(f"    Waiting for {ship_type_name}... ({elapsed}s)")
            time.sleep(120)

        if available_ships == 0:
            print(f"    SKIPPED: No {ship_type_name} available")
            if telegram_enabled:
                sendToBot(session, f"AUTO SEND SKIPPED\nRoute [{route_index + 1}/{total_routes}]: {origin_city['name']} -> {destination_city['name']}\nNo ships available")
            continue

        max_retries = 3
        retry_count = 0
        lock_acquired = False

        while retry_count < max_retries and not lock_acquired:
            print(f"    Acquiring shipping lock (attempt {retry_count + 1}/{max_retries})...")
            if acquire_shipping_lock(session, use_freighters=useFreighters, timeout=300):
                lock_acquired = True
                print(f"    Lock acquired.")
            else:
                retry_count += 1
                if retry_count < max_retries:
                    print(f"    Lock attempt {retry_count}/{max_retries} failed, retrying in 60s...")
                    time.sleep(60)

        if not lock_acquired:
            error_msg = f"Could not acquire shipping lock after {max_retries} attempts"
            print(f"    FAILED: {error_msg}")
            if telegram_enabled:
                sendToBot(session, f"AUTO SEND FAILED\nAccount: {session.username}\nRoute [{route_index + 1}/{total_routes}]: {origin_city['name']} -> {destination_city['name']}\nError: {error_msg}\nCompleted: {completed}/{total_routes}")
            break

        try:
            if useFreighters:
                ships_before = getAvailableFreighters(session)
            else:
                ships_before = getAvailableShips(session)

            if ships_before == 0:
                print(f"    Ships became unavailable, stopping")
                if telegram_enabled:
                    sendToBot(session, f"AUTO SEND STOPPED\nAccount: {session.username}\nRoute [{route_index + 1}/{total_routes}]: {origin_city['name']} -> {destination_city['name']}\nProblem: Ships became unavailable\nCompleted: {completed}/{total_routes}")
                break

            executeRoutes(session, [route], useFreighters)
            completed += 1
            print(f"    SUCCESS ({completed}/{total_routes})")

            if telegram_enabled:
                sendToBot(session, f"Auto Send [{completed}/{total_routes}]\n{origin_city['name']} -> {destination_city['name']}\nResources: {resources_desc}\nStatus: Sent")

        except Exception as send_error:
            error_msg = str(send_error)
            print(f"    FAILED: {error_msg}")
            if telegram_enabled:
                sendToBot(session, f"AUTO SEND FAILED\nAccount: {session.username}\nRoute [{route_index + 1}/{total_routes}]: {origin_city['name']} -> {destination_city['name']}\nError: {error_msg}\nCompleted: {completed}/{total_routes}")

        finally:
            release_shipping_lock(session, use_freighters=useFreighters)

    print(f"\n--- Auto Send complete: {completed}/{total_routes} shipments sent ---\n")
    if telegram_enabled:
        sendToBot(session, f"AUTO SEND COMPLETE\nAccount: {session.username}\nShipments: {completed}/{total_routes} sent")


def massDistributionMode(session, event, stdin_fd, predetermined_input, telegram_enabled):
    try:
        print_module_banner("Mass Distribution")
        print("Enter the full path to your CSV file:")
        print("(CSV must have columns: X, Y, Player, City, City_Location, Wood, Wine, Marble, Crystal, Sulphur, Hours)")
        print("(') Back to main menu")
        print("")
        csv_path = read(msg="CSV path: ", additionalValues=["'"])
        if csv_path == "'":
            event.set()
            return

        if not os.path.isfile(csv_path):
            print(f"File not found: {csv_path}")
            enter()
            event.set()
            return

        try:
            rows = []
            with open(csv_path, newline='', encoding='utf-8') as f:
                reader = csv.DictReader(f)
                required = {'X', 'Y', 'Player', 'City', 'City_Location', 'Wood', 'Wine', 'Marble', 'Crystal', 'Sulphur', 'Hours'}
                missing = required - set(reader.fieldnames or [])
                if missing:
                    print(f"CSV is missing columns: {', '.join(sorted(missing))}")
                    enter()
                    event.set()
                    return
                for row in reader:
                    rows.append(row)
        except Exception as e:
            print(f"Error reading CSV: {e}")
            enter()
            event.set()
            return

        if not rows:
            print("CSV file contains no data rows.")
            enter()
            event.set()
            return

        interval_hours = int(rows[0]['Hours'])

        print_module_banner("Mass Distribution")
        print(f"CSV loaded: {len(rows)} rows")
        print(f"Repeat interval: every {interval_hours} hour(s)")
        print("")
        print("What type of ships do you want to use?")
        print("(1) Merchant ships")
        print("(2) Freighters")
        print("(') Back to main menu")
        shiptype = read(min=1, max=2, digit=True, additionalValues=["'"])
        if shiptype == "'":
            event.set()
            return
        useFreighters = (shiptype == 2)

        print_module_banner("Mass Distribution")
        print("Select the SOURCE city (all resources will be sent from this city):")
        print("Island Luxury: (W) Wine | (M) Marble | (C) Crystal | (S) Sulfur")
        print("")
        source_city = chooseCity(session)

        print_module_banner("Mass Distribution")
        print(f"Source city:  {source_city['name']}")
        print(f"Ship type:    {'Freighters' if useFreighters else 'Merchant ships'}")
        print(f"CSV rows:     {len(rows)}")
        print(f"Interval:     every {interval_hours} hour(s)")
        print("")
        print("Proceed? [Y/n]")
        rta = read(values=["y", "Y", "n", "N", ""])
        if rta.lower() == "n":
            event.set()
            return

        enter()

    except KeyboardInterrupt:
        event.set()
        return

    set_child_mode(session)
    event.set()

    info = f"\nMass Distribution from {source_city['name']} every {interval_hours} hour(s)\n"
    setInfoSignal(session, info)

    try:
        do_it_mass_distribution(session, csv_path, source_city, useFreighters, interval_hours, telegram_enabled)
    except Exception as e:
        msg = "Error in:\n{}\nCause:\n{}".format(info, traceback.format_exc())
        sendToBot(session, msg)
    finally:
        session.logout()


def do_it_mass_distribution(session, csv_path, source_city, useFreighters, interval_hours, telegram_enabled):
    ship_type_name = "freighters" if useFreighters else "merchant ships"
    # CSV resource column order maps to materials_names [Wood, Wine, Marble, Crystal, Sulfur]
    csv_resource_cols = ['Wood', 'Wine', 'Marble', 'Crystal', 'Sulphur']

    while True:
        try:
            rows = []
            with open(csv_path, newline='', encoding='utf-8') as f:
                reader = csv.DictReader(f)
                for row in reader:
                    rows.append(row)
        except Exception as e:
            msg = f"MASS DISTRIBUTION ERROR\nAccount: {session.username}\nCould not read CSV: {e}"
            if telegram_enabled:
                sendToBot(session, msg)
            print(f"Error reading CSV: {e}")
            wait(3600)
            continue

        mismatches = []
        routes = []

        session.setStatus(f"[PROCESSING] Mass Distribution | Scanning {len(rows)} CSV rows...")

        for row_num, row in enumerate(rows, start=1):
            try:
                x = row['X'].strip()
                y = row['Y'].strip()
                expected_player = row['Player'].strip()
                expected_city = row['City'].strip()
                expected_location = str(row['City_Location'].strip())

                island_coords = f"xcoord={x}&ycoord={y}"
                html = session.get(f"view=island&{island_coords}")
                island = getIsland(html)

                cities_on_island = [c for c in island["cities"] if c.get("type") == "city"]

                matched_city = None
                for c in cities_on_island:
                    if c.get('name', '').strip().lower() == expected_city.lower():
                        matched_city = c
                        break

                if matched_city is None:
                    mismatches.append(
                        f"Row {row_num}: X={x} Y={y} Player={expected_player} City={expected_city} City_Location={expected_location}"
                    )
                    print(f"  [ROW {row_num}] MISMATCH - city not found on island [{x}:{y}]: {expected_city}")
                    continue

                resources = []
                for col in csv_resource_cols:
                    val = row.get(col, '0').strip()
                    resources.append(int(val) if val.isdigit() else 0)

                if sum(resources) == 0:
                    print(f"  [ROW {row_num}] No resources to send, skipping")
                    continue

                dest_city_html = session.get(city_url + str(matched_city['id']))
                dest_city = getCity(dest_city_html)

                route = (
                    source_city,
                    dest_city,
                    island["id"],
                    *resources,
                )
                routes.append((row_num, route, resources, dest_city['name'], expected_player, x, y))
                print(f"  [ROW {row_num}] OK: {dest_city['name']} ({expected_player}) [{x}:{y}]")

            except Exception as e:
                mismatches.append(
                    f"Row {row_num}: X={row.get('X','?')} Y={row.get('Y','?')} Player={row.get('Player','?')} City={row.get('City','?')} City_Location={row.get('City_Location','?')} - Error: {e}"
                )
                print(f"  [ROW {row_num}] ERROR: {e}")

        if mismatches and telegram_enabled:
            mismatch_msg = (
                f"MASS DISTRIBUTION MISMATCHES\n"
                f"Account: {session.username}\n"
                f"The following rows could not be verified and were skipped:\n\n"
                + "\n".join(mismatches)
            )
            sendToBot(session, mismatch_msg)

        if not routes:
            print("No valid routes to send.")
            if telegram_enabled:
                sendToBot(session, f"MASS DISTRIBUTION\nAccount: {session.username}\nNo valid routes found in CSV. Check for mismatches.")
        else:
            if telegram_enabled:
                sendToBot(session, (
                    f"MASS DISTRIBUTION SCHEDULED\n"
                    f"Account: {session.username}\n"
                    f"Source: {source_city['name']}\n"
                    f"{len(routes)} shipment(s) arranged and will be sent as soon as possible."
                ))

            completed = 0
            total = len(routes)

            for idx, (row_num, route, resources, dest_name, player, rx, ry) in enumerate(routes):
                resources_desc = ", ".join(
                    f"{addThousandSeparator(resources[i])} {materials_names[i]}"
                    for i in range(len(materials_names)) if resources[i] > 0
                )
                print(f"\n  [{idx + 1}/{total}] {source_city['name']} -> {dest_name} ({player}) [{rx}:{ry}]")
                print(f"    Resources: {resources_desc}")

                session.setStatus(f"[WAITING] Mass Distribution [{idx + 1}/{total}] | Waiting for {ship_type_name}...")

                ship_check_start = time.time()
                max_ship_wait = 3600
                available_ships = 0

                while True:
                    if useFreighters:
                        available_ships = getAvailableFreighters(session)
                    else:
                        available_ships = getAvailableShips(session)

                    if available_ships > 0:
                        print(f"    Found {available_ships} {ship_type_name}")
                        break

                    elapsed = int(time.time() - ship_check_start)
                    if elapsed > max_ship_wait:
                        print(f"    Timed out waiting for {ship_type_name}")
                        break
                    print(f"    Waiting for {ship_type_name}... ({elapsed}s)")
                    time.sleep(120)

                if available_ships == 0:
                    print(f"    SKIPPED: No {ship_type_name} available")
                    if telegram_enabled:
                        sendToBot(session, f"MASS DISTRIBUTION SKIPPED\nRoute [{idx + 1}/{total}]: {source_city['name']} -> {dest_name}\nNo ships available")
                    continue

                max_retries = 3
                retry_count = 0
                lock_acquired = False

                while retry_count < max_retries and not lock_acquired:
                    print(f"    Acquiring shipping lock (attempt {retry_count + 1}/{max_retries})...")
                    if acquire_shipping_lock(session, use_freighters=useFreighters, timeout=300):
                        lock_acquired = True
                        print(f"    Lock acquired.")
                    else:
                        retry_count += 1
                        if retry_count < max_retries:
                            print(f"    Retrying in 60s...")
                            time.sleep(60)

                if not lock_acquired:
                    print(f"    FAILED: Could not acquire shipping lock")
                    if telegram_enabled:
                        sendToBot(session, f"MASS DISTRIBUTION FAILED\nRoute [{idx + 1}/{total}]: {source_city['name']} -> {dest_name}\nCould not acquire shipping lock\nCompleted: {completed}/{total}")
                    continue

                try:
                    session.setStatus(f"[PROCESSING] Mass Distribution [{idx + 1}/{total}] {source_city['name']} -> {dest_name} | Sending...")
                    executeRoutes(session, [route], useFreighters)
                    completed += 1
                    print(f"    SUCCESS ({completed}/{total})")

                    if telegram_enabled:
                        sendToBot(session, f"Mass Distribution [{completed}/{total}]\n{source_city['name']} -> {dest_name} ({player}) [{rx}:{ry}]\nResources: {resources_desc}\nStatus: Sent")

                except Exception as send_error:
                    print(f"    FAILED: {send_error}")
                    if telegram_enabled:
                        sendToBot(session, f"MASS DISTRIBUTION FAILED\nRoute [{idx + 1}/{total}]: {source_city['name']} -> {dest_name}\nError: {send_error}\nCompleted: {completed}/{total}")

                finally:
                    release_shipping_lock(session, use_freighters=useFreighters)

            print(f"\n--- Mass Distribution complete: {completed}/{total} shipments sent ---")
            if telegram_enabled:
                sendToBot(session, f"MASS DISTRIBUTION COMPLETE\nAccount: {session.username}\nSource: {source_city['name']}\nShipments: {completed}/{total} sent")

        next_run = datetime.datetime.now() + datetime.timedelta(hours=interval_hours)
        print(f"\nNext run: {getDateTime(next_run.timestamp())}")
        session.setStatus(f"[WAITING] Mass Distribution | Next run: {getDateTime(next_run.timestamp())}")
        wait(interval_hours * 3600)
