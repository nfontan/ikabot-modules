                print(f"  {shipment['from']['name']}: Send {addThousandSeparator(shipment['amount'])} {resource_name}")
        
        print("")
        print("Cities RECEIVING (need more):")
        for shipment in shipments:
            if shipment['type'] == 'receiver':
                print(f"  {shipment['to']['name']}: Receive {addThousandSeparator(shipment['amount'])} {resource_name}")
        
        print("")
        print("(1) Confirm - Start balancing")
        print("(2) Cancel - Return to main menu")
