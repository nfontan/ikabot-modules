        for city_id in city_ids:
            if city_id not in excluded_city_ids:
                html_city = session.get(city_url + city_id)
                city = getCity(html_city)
                all_cities.append(city)
        
        if len(all_cities) == 0:
            print("No cities available for balancing!")
            enter()
            event.set()
            return
        
        # STEP 4: Calculate totals and distribution
        print_module_banner("Calculating Distribution")
