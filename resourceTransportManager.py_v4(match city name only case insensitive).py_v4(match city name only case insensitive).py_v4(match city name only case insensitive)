        total_resource = 0
        city_amounts = []
        for city in all_cities:
            amount = city['availableResources'][resource_index]
            total_resource += amount
            city_amounts.append({
                'city': city,
                'current': amount
            })
        
        # Calculate target amount per city
        target_per_city = total_resource // len(all_cities)
        
