        # Calculate shipments needed
        shipments = []
        for city_info in city_amounts:
            city = city_info['city']
            current = city_info['current']
            difference = current - target_per_city
            
            if difference > 0:
                # This city has excess - will send OUT
                shipments.append({
                    'from': city,
                    'amount': difference,
                    'type': 'sender'
                })
            elif difference < 0:
                # This city needs more - will receive
                shipments.append({
                    'to': city,
                    'amount': abs(difference),
                    'type': 'receiver'
                })
        
        # Display shipment plan
        print("SHIPMENT PLAN:")
        print("")
        print("Cities SENDING (have excess):")
        for shipment in shipments:
