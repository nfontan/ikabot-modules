        return
    
    set_child_mode(session)
    event.set()
    
    # Execute balancing
    info = f"\nBalancing {resource_name} across {len(all_cities)} cities\n"
    setInfoSignal(session, info)
    
    try:
        do_even_distribution(session, shipments, resource_index, resource_name, useFreighters, telegram_enabled, notify_partial, notify_all)
